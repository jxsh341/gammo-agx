# Gammo AGX Environment Configuration
# Copy this file to .env and fill in your values

# ── Supabase ──
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── AI Models ──
# Path to your GGUF model files
GEMMA_MODEL_PATH=models/gemma-3-4b-instruct-q4_k_m.gguf
DEEPSEEK_MODEL_PATH=models/deepseek-r1-distill-qwen-7b-q4_k_m.gguf

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret

# ── Physics Engine ──
JAX_ENABLE_X64=True
JAX_PLATFORM_NAME=gpu

# ── Discovery Loop ──
LOOP_INTERVAL_SECONDS=30
LOOP_MAX_CONCURRENT=2
LOOP_AUTO_START=True

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=logs/gammo_agx.log
